file path=opt/header-tests/cfg/c-symbols/stddef_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/stdio_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/stdlib_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/stdnoreturn_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/string_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/strings_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/sys_atomic_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/sys_mman_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/sys_stat_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/sys_time_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/sys_timeb_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/threads_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/time_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/ucontext_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/unistd_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/wchar_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/wctype_h.cfg mode=0444
dir  path=opt/header-tests/runfiles
file path=opt/header-tests/runfiles/default.run mode=0444
dir  path=opt/header-tests/tests
dir  path=opt/header-tests/tests/c-symbols
hardlink path=opt/header-tests/tests/c-symbols/assert_h target=setup
hardlink path=opt/header-tests/tests/c-symbols/ctype_h target=setup
hardlink path=opt/header-tests/tests/c-symbols/dirent_h target=setup
hardlink path=opt/header-tests/tests/c-symbols/fcntl_h target=setup
hardlink path=opt/header-tests/tests/c-symbols/locale_h target=setup

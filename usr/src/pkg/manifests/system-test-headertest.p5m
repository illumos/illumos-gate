file path=opt/header-tests/tests/common/c_symbols_test_32 mode=0555
file path=opt/header-tests/tests/common/c_symbols_test_64 mode=0555
license lic_CDDL license=lic_CDDL
depend type=require fmri=system/test/testrunner

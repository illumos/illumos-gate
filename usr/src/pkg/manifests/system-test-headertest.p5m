file path=opt/header-tests/cfg/c-symbols/math_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/netdb_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/pthread_h.cfg mode=0444
file path=opt/header-tests/cfg/c-symbols/signal_h.cfg mode=0444

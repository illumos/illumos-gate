set name=pkg.fmri value=pkg:/system/test/headertest@$(PKGVERS)
set name=pkg.summary value="Header File Symbols Test Suite"
set name=pkg.description value="Header File Symbols Test Suite"
set name=info.classification \
    value=org.opensolaris.category.2008:Development/System
set name=variant.arch value=$(ARCH)
dir  path=opt/header-tests
file path=opt/header-tests/README mode=0444
dir  path=opt/header-tests/bin
file path=opt/header-tests/bin/headertest mode=0555
dir  path=opt/header-tests/cfg
file path=opt/header-tests/cfg/README mode=0444
dir  path=opt/header-tests/cfg/c-symbols
file path=opt/header-tests/cfg/c-symbols-env.cfg mode=0444
